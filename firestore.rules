rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read their own user document
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow write: if request.auth.uid == userId && request.auth.uid != null;
    }

    // Allow reading all roles data (for access control UI)
    match /roles/{document=**} {
      allow read: if request.auth.uid != null;
      allow write: if false;
    }

    // Allow authenticated users to read/write their own data in other collections
    match /{document=**} {
      allow read, write: if request.auth.uid != null && request.auth.uid == resource.data.userId;
    }
  }
}
